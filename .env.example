# Gas Tracker — Environment Variables
#
# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# Secrets (pg_password, minio_access_key, minio_secret_key, jwt_key,
# admin_password) are auto-generated by the init service on first run
# and stored in the Docker "secrets" volume.  You do NOT need to set them here.

# ── App container ─────────────────────────────────────────────────────────────

# Timezone (used by entrypoint to symlink /etc/localtime)
TZ=America/New_York

# ASP.NET Core environment (Production | Development)
ASPNETCORE_ENVIRONMENT=Production

# ── Database ──────────────────────────────────────────────────────────────────

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=gas
POSTGRES_DB=gastracker

# ── MinIO ─────────────────────────────────────────────────────────────────────

MinIO__Endpoint=minio:9000
MinIO__BucketName=gas-receipts
MinIO__UseSSL=false

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated allowed origins (use * for any)
AllowedOrigins=*

# ── JWT ───────────────────────────────────────────────────────────────────────

Jwt__Issuer=gas-api
Jwt__Audience=gas-app

# ── Admin seed ────────────────────────────────────────────────────────────────

AdminSeed__Email=admin@gastracker.local
AdminSeed__FirstName=Admin
AdminSeed__LastName=User

# ── Paperless-ngx sync (disabled by default) ──────────────────────────────────

Paperless__Enabled=false
# Paperless__BaseUrl=http://paperless:8000
# Paperless__Token=
